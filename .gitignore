# ════════════════════════════════════════════════════════════
# .gitignore — Final Production Hardening
# ════════════════════════════════════════════════════════════

# ── Terraform ─────────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
*.tfvars
!*.tfvars.example

# ── Secrets & Credentials ────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.*
kubeconfig
kubeconfig_agent/

# ── Ansible ──────────────────────────────────────────────
ansible/inventory/hosts.ini
!ansible/inventory/hosts.ini.example

# ── Python ────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.venv/
.Python

# ── IDE & OS ──────────────────────────────────────────────
.vscode/
.idea/
.vs/
.DS_Store
Thumbs.db
*.swp
*.swo

# ── Logs & Temp ──────────────────────────────────────────
*.log
/tmp/
scratch/
