# Copy to .env and fill in real values. Never commit .env.
#   cp .env.example .env   (Linux/macOS)
#   copy .env.example .env (Windows)

# Required — Google AI (Gemini)
GOOGLE_API_KEY=

# Model (defaults match app/config.py)
MODEL_NAME=gemini-2.5-flash-lite
MODEL_TEMPERATURE=0

# Kubernetes / MCP
# Windows example: C:\Users\you\.kube\config
KUBECONFIG_PATH="~/.kube/config"
NPX_PATH=npx

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# Optional — LangSmith tracing (set LANGCHAIN_TRACING_V2=false to disable)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=k8s-ai-agent

# Guardrails
GUARDRAILS_ENABLED=true

# Postgres (docker-compose: db, result, worker, Temporal)
# POSTGRES_PWD MUST equal POSTGRES_PASSWORD (Temporal reads PWD; Postgres image uses PASSWORD on first start).
# If you see "password authentication failed for user postgres", fix the match or reset the volume:
#   docker compose down -v && docker compose up -d --build
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PWD=change-me-strong-password
POSTGRES_DB=postgres

# ── API Authentication ───────────────────────────────────
# For dev: leave empty. For prod: set APP_ENV=prod and set a strong key here.
# Header name: X-API-Key
# API_AUTH_KEY=your-secure-static-key-here

# ── Networking ───────────────────────────────────────────
# Comma-separated list of allowed CORS origins
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Options: dev, staging, prod
APP_ENV=dev
