# ════════════════════════════════════════════════════════════
# .env.example — All environment variables for the project
# Copy to .env and fill in your values. NEVER commit .env!
#   cp .env.example .env
# ════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_use_vault_in_prod
POSTGRES_PWD=changeme_use_vault_in_prod
POSTGRES_DB=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_use_vault_in_prod

# ── AI SRE Agent ──────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here
MODEL_NAME=gemini-2.5-flash-lite
KUBECONFIG_PATH=~/.kube/config

# ── LangSmith (tracing + evals) ──────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=k8s-ai-agent

# ── Temporal Cloud (workflow orchestration) ───────────────
TEMPORAL_ADDRESS=your-namespace.tmprl.cloud:7233
TEMPORAL_NAMESPACE=your-namespace
TEMPORAL_API_KEY=your_temporal_api_key_here

# ── MCP Server ────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8000

# ── Infisical (dev secrets — prod uses Vault) ─────────────
# INFISICAL_TOKEN=your_infisical_token_here

# ── Vault (production K8s deployment) ─────────────────────
VAULT_ADDR=http://127.0.0.1:8200
# VAULT_TOKEN=your_vault_token_here

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
APP_ENV=dev
DEBUG=false
LOG_LEVEL=INFO

# ── API Authentication ───────────────────────────────────
# API_AUTH_KEY=your-secure-static-key-here

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
