# ════════════════════════════════════════════════════════════
# .dockerignore — Step 3: What Goes Into The Image
# Prevents secrets, junk, and dev artifacts from leaking in
# ════════════════════════════════════════════════════════════

# ── Version control ───────────────────────────────────────────
.git
.github
.gitignore
*.md
!README.md

# ── Secrets — CRITICAL ────────────────────────────────────────
.env
.env.*
*.pem
*.key
id_rsa
id_rsa.*
kubeconfig
kubeconfig_agent/
terraform.tfstate*
*.tfvars

# ── IDE / Editor ──────────────────────────────────────────────
.vscode
.idea
.cursor
.windsurf
.trae
.zed

# ── AI tooling caches ─────────────────────────────────────────
.gemini
.insforge
.agent
.agents
.augment
.claude
.kilocode
.qoder
.qwen
.roo

# ── Python ────────────────────────────────────────────────────
venv/
venv_win/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/

# ── Node.js ───────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# ── .NET ──────────────────────────────────────────────────────
bin/
obj/
*.user

# ── Logs and temp ─────────────────────────────────────────────
*.log
*.tmp
*.bak
dump.rdb
agent_temp_logs.txt
vault-logs.txt
server_startup.log
full_server_log.txt
uvicorn_debug.log
debug_out.log
curl_result.txt
final_result.json
test_output.txt
worker_error.txt

# ── Test and CI files ─────────────────────────────────────────
tests/
test_*.py
*_test.py
Dockerfile*
docker-compose*.yml
.pre-commit-config.yaml
custom-rules.toml
setup-hooks.sh
