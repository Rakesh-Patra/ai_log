# Secrets — never commit real credentials
.env
.env.*
!.env.example

# Kubernetes secrets (real values) — only templates belong in git
k8s/db-secret.yaml
k8s/redis-secret.yaml
!k8s/*-secret.example.yaml

*.pyc
project.lock.json
bin/
obj/
.vs/
node_modules/

# Local-only logs (do not commit)
agent_temp_logs.txt
vault-logs.txt

# Never commit service account token secrets
k8s/reviewer-secret.yaml

# Local media / docs exports (ignore unless intentionally tracked)
*.png
linkedin_carousel*.pdf
final_combined_carousel.pdf

# Local helper scripts for generating PDFs
make_pdf.py
merge_pdf.py
