# ════════════════════════════════════════════════════════════
# hosts.ini.example — Copy and fill with your EC2 IP
#   cp hosts.ini.example hosts.ini
# ════════════════════════════════════════════════════════════

[k3s]
# Replace with your EC2 public IP from `terraform output instance_public_ip`
k3s-host ansible_host=YOUR_EC2_IP ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/your-key.pem

[k3s:vars]
ansible_python_interpreter=/usr/bin/python3
