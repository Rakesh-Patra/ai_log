# Copy your kubeconfig here as kubeconfig_agent and replace the cluster server
# 127.0.0.1 with host.docker.internal so containers reach Kind on the host.
#
# Example:
#   server: https://127.0.0.1:44821   ->   server: https://host.docker.internal:44821
#
# Recreate after Kind restarts (port may change):
#   kind export kubeconfig --name <cluster> -q
#   # then edit the server line as above
